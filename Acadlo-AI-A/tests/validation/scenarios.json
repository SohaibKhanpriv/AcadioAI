      "turns": [
        {
          "turn": 1,
          "action": "start",
          "input": null,
          "expected": { "lesson_complete": false }
        },
        {
          "turn": 2,
          "action": "turn",
          "input": "7",
          "expected": {
            "contains_any": ["try", "hint", "think", "again", "close", "not quite"],
            "lesson_complete": false
          }
        }
      ]
    },
    {
      "id": "teach_two_wrong",
      "name": "Two consecutive wrong - simplify + different method",
