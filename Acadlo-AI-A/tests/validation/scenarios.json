    {
      "id": "mcq_trigger",
      "name": "Random answer (9999) - tutor switches to MCQ",
      "category": "mcq",
      "setup": {
        "tenant_id": "test_tenant",
        "student_id": "student_mcq_004",
        "lesson_id": "math_division",
