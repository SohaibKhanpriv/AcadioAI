      "turns": [
        { "turn": 1, "action": "start", "input": null, "expected": { "lesson_complete": false } },
        { "turn": 2, "action": "turn", "input": "9999", "expected": { "mcq_format": true, "lesson_complete": false } },
        {
          "turn": 3,
          "action": "turn",
          "input": "the second one",
          "expected": {
            "contains_any": ["A", "B", "C", "D", "choose", "letter", "option"],
            "lesson_complete": false
          }
        }
      ]
