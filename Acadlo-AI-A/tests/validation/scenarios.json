        "objectives": null
      },
      "turns": [
        {
          "turn": 1,
          "action": "start",
          "input": null,
          "expected": { "lesson_complete": false }
        },
        {
          "turn": 2,
          "action": "turn",
          "input": "9999",
          "expected": {
            "mcq_format": true,
            "contains_any": ["A)", "B)", "C)", "D)", "choose", "think"],
            "lesson_complete": false
          }
        }
      ]
    },
    {
      "id": "mcq_correct_exit",
      "name": "MCQ - Student answers correctly, exits MCQ and resumes",
      "category": "mcq",
      "setup": {
        "tenant_id": "test_tenant",
        "student_id": "student_mcq_exit_004b",
        "lesson_id": "math_division",
