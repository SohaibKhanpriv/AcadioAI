{
  "version": "1.0",
  "base_url": "http://localhost:8000",
  "scenarios": [
    {
      "id": "onboarding_full",
      "name": "Onboarding - First-time student, no lesson provided",
      "category": "onboarding",
      "setup": {
        "tenant_id": "test_tenant",
        "student_id": "student_new_001",
        "lesson_id": "pending",
        "objective_ids": [],
        "objectives": null
      },
      "turns": [
        {
          "turn": 1,
          "action": "start",
          "input": null,
          "expected": {
            "contains_any": ["topic", "what do you want to learn", "subject", "question", "grade", "level", "language"],
            "must_not_contain": ["let's start with", "here's a question", "solve this"],
            "lesson_complete": false
          }
        },
        {
          "turn": 2,
          "action": "turn",
          "input": "division, grade 4, beginner, English",
          "expected": {
            "must_not_contain": ["what grade", "what level", "what language"],
            "lesson_complete": false
          }
        }
      ]
    },
    {
      "id": "onboarding_returning",
      "name": "Onboarding - Returning student with full profile + lesson, skips to teaching",
      "category": "onboarding",
      "setup": {
        "tenant_id": "test_tenant",
        "student_id": "student_returning_001",
        "lesson_id": "math_division",
        "objective_ids": ["obj_division_intro"],
        "objectives": null
      },
      "turns": [
        {
          "turn": 1,
          "action": "start",
          "input": null,
          "expected": {
            "must_not_contain": ["what grade", "what level", "what topic", "what language"],
            "lesson_complete": false
          }
        }
      ]
    },
    {
      "id": "onboarding_chat_before_answer",
