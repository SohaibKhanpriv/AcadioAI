          "input": null,
          "expected": {
            "contains_any": ["grade", "level", "language", "question"],
            "lesson_complete": false
          }
        }
      ]
    },
    {
      "id": "teach_one_wrong",
      "name": "One wrong answer - hint, ask to try again",
