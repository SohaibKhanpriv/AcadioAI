          "turn": 2,
          "action": "turn",
          "input": "10",
          "expected": { "lesson_complete": false }
        },
        {
          "turn": 3,
          "action": "turn",
          "input": "12",
          "expected": {
            "contains_any": ["different", "simpler", "another way", "try", "method", "objects", "draw"],
            "lesson_complete": false
          }
        }
      ]
    },
    {
      "id": "teach_correct_answer",
